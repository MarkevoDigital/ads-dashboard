# Copie para .env e preencha. NUNCA versione o .env (ja esta no .gitignore).
# Estas variaveis sobrescrevem o config.json.

# Fonte de dados: api | service_account | csv_publicado | sample
FONTE_DADOS=api
DIAS_BUSCA=60

# --- Meta Ads (Marketing API) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_IDS=act_000000000000000
META_API_VERSION=v21.0

# --- Google Ads API ---
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_LOGIN_CUSTOMER_ID=0000000000
GOOGLE_CUSTOMER_IDS=0000000000

# --- Acesso do cliente (protege o link) ---
DASH_USER=cliente
DASH_PASSWORD=troque-esta-senha

# --- Token do cron de atualizacao diaria ---
CRON_TOKEN=gere-um-token-aleatorio
